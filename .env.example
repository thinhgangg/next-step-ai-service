# App
PORT=9000
APP_NAME="AI Job Matching Server"
DEBUG=True

# Database
# Supabase pooler example:
# postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=require

# Optional DB parts, useful for scripts/docs
DB_USERNAME=postgres
DB_PASSWORD=<password>
DB_HOST=<pooler-host>
DB_PORT=6543
DB_NAME=postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# AI
GEMINI_API_KEY=<your-gemini-api-key>
CV_AI_ENRICHMENT_ENABLED=True

# Auth
JWT_ACCESS_SECRET=<replace-with-long-random-secret>
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=<replace-with-long-random-secret>
JWT_REFRESH_EXPIRES_IN=7d
